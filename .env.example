# Required: your OpenAI API key — powers the default chat model (gpt-4o-mini)
# for most traffic, plus RAG embeddings (ingest + retrieve).
OPENAI_API_KEY=

# Required: your Anthropic API key — reserved for the HRIS-write flow only
# (proposing/confirming an HR record change). See CLAUDE.md's "Model
# routing" section for why.
ANTHROPIC_API_KEY=

# Optional: Langfuse Cloud tracing (question/tool-call/answer per persona).
# Leave unset to disable tracing entirely — the app runs fine without it.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional: shows a "Demo" badge in the UI to indicate sample content (default: false)
DEMO_MODE=false
