# Required: your Anthropic API key (Claude orchestrator/chat)
ANTHROPIC_API_KEY=

# Required: your OpenAI API key — embeddings only (RAG ingest + retrieve),
# no longer used for chat
OPENAI_API_KEY=

# Optional: Langfuse Cloud tracing (question/tool-call/answer per persona).
# Leave unset to disable tracing entirely — the app runs fine without it.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional: shows a "Demo" badge in the UI to indicate sample content (default: false)
DEMO_MODE=false
